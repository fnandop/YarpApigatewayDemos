{
  "Logging": {
    "LogLevel": {
      "Default": "Trace",

      "Microsoft": "Trace",
      "Microsoft.Hosting.Lifetime": "Trace",
      "Microsoft.AspNetCore": "Trace",

      // IdentityServer (Duende + IdentityServer4 commonly log under these)
      "Duende": "Trace",
      "Duende.IdentityServer": "Trace",
      "IdentityServer4": "Trace",

      // Token creation/validation + protocol stuff
      "Microsoft.IdentityModel": "Trace",
      "IdentityModel": "Trace",

      // HTTP client traffic used for discovery/introspection/etc.
      "System.Net.Http.HttpClient": "Trace",

      // If you use EF Core stores (configuration/operational stores)
      "Microsoft.EntityFrameworkCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    },

    "Console": {
      "IncludeScopes": true
    }
  },

  "AllowedHosts": "*"
}